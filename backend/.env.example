# Copy to .env and fill in. Do not commit real secrets.

# MySQL (协议 §2 / resource.md)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=SmartRelay
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=SmartRelay

# JWT
JWT_SECRET=change-to-long-random-string
JWT_EXPIRE_HOURS=720

# WeChat 小程序（占位：在微信公众平台获取后填入）
WECHAT_APPID=
WECHAT_SECRET=

# MQTT Broker（服务端连接账号，与 resource.md 一致）
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=SmartRelay
MQTT_PASSWORD=CHANGE_ME
MQTT_CLIENT_ID=smartrelay_server

# 协议 §5.6 / §5.7
ONLINE_GRACE_SECONDS=10
COMMAND_ACK_TIMEOUT_SECONDS=30

# 迁移脚本默认管理员（仅 scripts/run_migrations 使用）
ADMIN_DEFAULT_PASSWORD=admin123
