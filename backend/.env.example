# 复制为 .env 后修改；勿提交真实生产密码
# 默认值仅便于本地联调，与 resource.example.md 对齐时请自行覆盖

APP_NAME=SmartRelay API
PUBLIC_BASE_URL=http://127.0.0.1:8000
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=SmartRelay
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=SmartRelay

JWT_SECRET=change-me-use-long-random-in-production

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=SmartRelay
MQTT_PASSWORD=change_me
MQTT_CLIENT_ID=sr_backend_v1

# 设备离线判定（秒），默认 15，与协议一致
DEVICE_OFFLINE_SECONDS=15

# 默认管理员（首次启动写入 admin_users，密码 bcrypt）
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# 微信小程序（留空则 dev 模式用 code 派生 openid）
WECHAT_APP_ID=
WECHAT_SECRET=

UPLOAD_DIR=uploads
