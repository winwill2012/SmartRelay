/* 全局：冷灰底 + 统一卡片与主色，与各页渐变顶栏搭配 */
page {
  background-color: #f3f6fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
}

.mp-primary {
  color: #2563eb;
}

.mp-muted {
  color: #8a8f99;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 55%, #1d4ed8 100%);
  color: #fff;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.28);
}

.filter-chip {
  border-radius: 9999rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.filter-chip-on {
  border: 2rpx solid #2563eb;
  background: #2563eb;
  color: #fff;
}

.filter-chip-off {
  border: 2rpx solid #e2e8f0;
  background: #fff;
  color: #334155;
}

/* 列表开关轨道 72×32 → 144rpx 64rpx */
.switch-track {
  position: relative;
  width: 144rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}
.switch-track.on {
  background: #10b981;
}
.switch-track.off {
  background: #cbd5e1;
}
.switch-knob {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  background: #fff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}
.switch-track.on .switch-knob {
  transform: translateX(80rpx);
}

.switch-track-wide {
  width: 224rpx;
  height: 128rpx;
}
.switch-track-wide .switch-knob {
  width: 96rpx;
  height: 96rpx;
  top: 16rpx;
  left: 16rpx;
}
.switch-track-wide.on .switch-knob {
  transform: translateX(96rpx);
}

.card {
  border-radius: 28rpx;
  background: #fff;
  border: 2rpx solid rgba(241, 245, 249, 0.95);
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.055);
}

/* 顶部氛围光（固定定位，pointer-events:none），用于首页等 */
.ambient-top {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  height: 300rpx;
  background: linear-gradient(
    180deg,
    rgba(219, 234, 254, 0.65) 0%,
    rgba(243, 246, 251, 0) 100%
  );
  z-index: 0;
  pointer-events: none;
}

.tap-fade {
  opacity: 0.92;
}

.safe-bottom {
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.fab-add {
  position: fixed;
  right: 32rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 9999rpx;
  background: linear-gradient(145deg, #3b82f6 0%, #2563eb 45%, #1d4ed8 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 36rpx rgba(37, 99, 235, 0.38),
    0 0 0 1rpx rgba(255, 255, 255, 0.35) inset;
  z-index: 50;
}
