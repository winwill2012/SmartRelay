page {
  background-color: #f5f7fa;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.mp-primary {
  color: #2563eb;
}

.mp-muted {
  color: #8a8f99;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.filter-chip {
  border-radius: 9999rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.filter-chip-on {
  border: 2rpx solid #2563eb;
  background: #2563eb;
  color: #fff;
}

.filter-chip-off {
  border: 2rpx solid #e2e8f0;
  background: #fff;
  color: #334155;
}

/* 列表开关轨道 72×32 → 144rpx 64rpx */
.switch-track {
  position: relative;
  width: 144rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}
.switch-track.on {
  background: #10b981;
}
.switch-track.off {
  background: #cbd5e1;
}
.switch-knob {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  background: #fff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}
.switch-track.on .switch-knob {
  transform: translateX(80rpx);
}

.switch-track-wide {
  width: 224rpx;
  height: 128rpx;
}
.switch-track-wide .switch-knob {
  width: 96rpx;
  height: 96rpx;
  top: 16rpx;
  left: 16rpx;
}
.switch-track-wide.on .switch-knob {
  transform: translateX(96rpx);
}

.card {
  border-radius: 32rpx;
  background: #fff;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}

.safe-bottom {
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.fab-add {
  position: fixed;
  right: 32rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 9999rpx;
  background: #2563eb;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(37, 99, 235, 0.35);
  z-index: 50;
}
