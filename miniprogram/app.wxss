page {
  background-color: #f0f2f5;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.text-muted {
  color: #6b7280;
  font-size: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tag-online {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #ecfdf5;
  color: #059669;
}

.tag-offline {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #f3f4f6;
  color: #6b7280;
}
