.page {
  padding: 32rpx 32rpx 80rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 80rpx 0;
}

.head {
  padding: 40rpx 32rpx 48rpx;
}

.head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.name-block {
  flex: 1;
  min-width: 0;
}

.dev-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #0f172a;
  display: block;
  word-break: break-all;
}

.edit-tip {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #2563eb;
}

.dev-id {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  font-family: ui-monospace, monospace;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.badge-on {
  background: #ecfdf5;
  color: #047857;
}

.badge-off {
  background: #f1f5f9;
  color: #64748b;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
}

.dot-on {
  background: #10b981;
}

.dot-off {
  background: #94a3b8;
}

.switch-wrap {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
}

.relay-label {
  margin-top: 0;
  margin-left: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
  text-align: center;
}

.relay-label.on {
  color: #047857;
}

.menu {
  margin-top: 32rpx;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.menu-row.border {
  border-bottom: 2rpx solid #f8fafc;
}

.sub {
  font-size: 26rpx;
  color: #94a3b8;
}

.chev {
  color: #cbd5e1;
  font-size: 32rpx;
}

.share-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  min-height: 84rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #1e293b;
  background: transparent;
  text-align: left;
  line-height: 1.2;
}

.share-btn::after {
  border: none;
}

.btn-unbind {
  margin-top: 48rpx;
  width: 100%;
  border-radius: 24rpx;
  border: 2rpx solid #fecaca;
  background: #fff;
  color: #dc2626;
  font-size: 28rpx;
  line-height: 84rpx;
  padding: 0;
}

.btn-unbind::after {
  border: none;
}
