.page {
  padding-bottom: 48rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.switch-card .tip {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.actions .link {
  background: transparent;
  color: #2563eb;
  text-align: left;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.actions .danger {
  color: #b91c1c;
}

.state {
  text-align: center;
  padding: 80rpx;
  color: #6b7280;
}
