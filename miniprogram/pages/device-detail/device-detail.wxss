.page {
  padding: 32rpx 32rpx 80rpx;
  position: relative;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 80rpx 0;
}

.head {
  padding: 36rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #fafbff 0%, #ffffff 50%);
}

.head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.name-block {
  flex: 1;
  min-width: 0;
}

.dev-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #0f172a;
  display: block;
  word-break: break-all;
}

.dev-id {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
  font-family: ui-monospace, monospace;
  word-break: break-all;
  line-height: 1.4;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.badge-on {
  background: #ecfdf5;
  color: #047857;
}

.badge-off {
  background: #f1f5f9;
  color: #64748b;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
}

.dot-on {
  background: #10b981;
}

.dot-off {
  background: #94a3b8;
}

/* 控制区：浅底圆角台 + 居中开关，避免大留白却不再堆长文案 */
.relay-zone {
  margin-top: 32rpx;
  padding: 32rpx 24rpx 36rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #f1f5f9;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.relay-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #64748b;
  letter-spacing: 0.02em;
}

.relay-label.on {
  color: #047857;
}

/* 圆形电源按钮：点击 hover缩放 + 透明度反馈 */
.relay-btn {
  width: 208rpx;
  height: 208rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.relay-btn--on {
  background: linear-gradient(145deg, #34d399 0%, #10b981 42%, #059669 100%);
  box-shadow: 0 14rpx 40rpx rgba(16, 185, 129, 0.32),
    0 0 0 2rpx rgba(255, 255, 255, 0.35) inset;
}

.relay-btn--off {
  background: linear-gradient(145deg, #f8fafc 0%, #e2e8f0 50%, #cbd5e1 100%);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.1),
    0 0 0 2rpx rgba(255, 255, 255, 0.65) inset;
}

.relay-btn-text {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.04em;
}

.relay-btn--off .relay-btn-text {
  color: #475569;
}

.relay-btn-hover {
  transform: scale(0.9);
  opacity: 0.88;
}

.relay-hint {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

.menu {
  margin-top: 32rpx;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.menu-row.border {
  border-bottom: 2rpx solid #f8fafc;
}

.menu-row-hover {
  background: #f8fafc;
}

.sub {
  font-size: 26rpx;
  color: #94a3b8;
}

.menu-name-peek {
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chev {
  color: #cbd5e1;
  font-size: 32rpx;
}

.share-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  min-height: 84rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #1e293b;
  background: transparent;
  text-align: left;
  line-height: 1.2;
}

.share-btn::after {
  border: none;
}

.btn-unbind {
  margin-top: 48rpx;
  width: 100%;
  border-radius: 24rpx;
  border: 2rpx solid rgba(252, 165, 165, 0.85);
  background: linear-gradient(180deg, #fff 0%, #fff5f5 100%);
  color: #dc2626;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 84rpx;
  padding: 0;
}

.btn-unbind::after {
  border: none;
}
