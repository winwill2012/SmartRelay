<view class="page">
  <view class="toolbar text-muted">每设备最多 10 条（协议约定）；当前 {{items.length}} / 10</view>

  <view wx:if="{{loading}}" class="state">加载中...</view>
  <block wx:else>
    <view wx:for="{{items}}" wx:key="id" class="card item">
      <view class="row">
        <text class="cron">{{item.cron_expr}}</text>
        <switch checked="{{item.enabled === 1}}" data-id="{{item.id}}" bindchange="onToggle" />
      </view>
      <view class="text-muted">动作: {{item.action}}</view>
      <view class="ops">
        <button size="mini" data-id="{{item.id}}" bindtap="onEdit">编辑</button>
        <button size="mini" type="warn" data-id="{{item.id}}" bindtap="onDelete">删除</button>
      </view>
    </view>

    <view class="card" wx:if="{{items.length < 10}}">
      <view class="label">cron（6 段：秒 分 时 日 月 周，与后端 Spring/Python 对齐）</view>
      <input class="input" value="{{form.cron_expr}}" placeholder="0 0 8 * * ?" bindinput="onCron" />
      <view class="label">动作</view>
      <picker mode="selector" range="{{actions}}" value="{{actionIndex}}" bindchange="onActionPick">
        <view class="picker">{{actions[actionIndex]}}</view>
      </picker>
      <button class="btn-primary" loading="{{saving}}" bindtap="onCreate">新建</button>
    </view>
  </block>
</view>
