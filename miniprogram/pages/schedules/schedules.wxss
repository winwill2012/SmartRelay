.page {
  padding: 24rpx 32rpx 80rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 48rpx 0;
  font-size: 28rpx;
}

.hint.err {
  color: #dc2626;
}

.card.item {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(241, 245, 249, 0.95);
}

.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.detail {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.4;
}

.actions {
  margin-top: 20rpx;
  display: flex;
  gap: 32rpx;
  font-size: 28rpx;
}

.link {
  color: #2563eb;
}

.del {
  color: #dc2626;
}

.btn-add {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 55%, #1d4ed8 100%);
  color: #fff;
  font-weight: 600;
  font-size: 30rpx;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.28);
}
