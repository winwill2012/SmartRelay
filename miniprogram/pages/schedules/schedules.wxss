.page {
  padding-bottom: 48rpx;
}

.toolbar {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
}

.state {
  text-align: center;
  padding: 80rpx;
  color: #6b7280;
}

.item .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.cron {
  font-family: ui-monospace, monospace;
  font-size: 26rpx;
}

.ops {
  margin-top: 12rpx;
  display: flex;
  gap: 16rpx;
}

.label {
  margin-top: 12rpx;
  color: #374151;
  font-size: 26rpx;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  margin: 8rpx 0;
  font-family: ui-monospace, monospace;
  font-size: 24rpx;
}

.picker {
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
}
