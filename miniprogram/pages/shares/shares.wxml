<view class="page">
  <view wx:if="{{loading}}" class="hint">加载中…</view>
  <view wx:elif="{{list.length === 0}}" class="hint">暂无分享记录</view>
  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="card item">
      <text class="t">{{item.device_name || item.device_id || '未知设备'}}</text>
      <text class="s">{{item.status || item.role || '已分享'}}</text>
      <view class="row-actions">
        <button class="act act-detail" data-index="{{index}}" bindtap="onViewDetail">查看详情</button>
        <button class="act act-cancel" data-index="{{index}}" bindtap="onCancelShare">取消分享</button>
      </view>
    </view>
  </view>
</view>
