.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 80rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #334155;
}

.empty-sub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #64748b;
}

.btn-login {
  margin-top: 80rpx;
  padding: 24rpx 80rpx;
  border-radius: 9999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.main {
  padding: 24rpx 32rpx 0;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
  padding: 48rpx 0;
}

.hint.err {
  color: #dc2626;
}

.device-row {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.device-inner {
  display: flex;
  align-items: stretch;
}

.device-main {
  flex: 1;
  min-width: 0;
  padding: 32rpx 24rpx;
}

.device-main-hover {
  background: #f8fafc;
}

.device-main-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.device-text-block {
  flex: 1;
  min-width: 0;
}

.device-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-badge-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-on {
  background: #ecfdf5;
  color: #047857;
}

.badge-off {
  background: #f1f5f9;
  color: #64748b;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
}

.dot-on {
  background: #10b981;
}

.dot-off {
  background: #94a3b8;
}

.schedule-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-inner .switch-track {
  align-self: center;
  margin-right: 24rpx;
}

.fab-add {
  text-decoration: none;
}

.fab-plus {
  font-size: 64rpx;
  font-weight: 300;
  line-height: 1;
}

.fab-add-hover {
  opacity: 0.92;
}
