.page {
  box-sizing: border-box;
  position: relative;
  min-height: 100vh;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.layer {
  position: relative;
  z-index: 1;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 80rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #334155;
}

.empty-sub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #64748b;
}

.btn-login {
  margin-top: 80rpx;
  padding: 24rpx 80rpx;
  border-radius: 9999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.main {
  padding: 24rpx 32rpx 0;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
  padding: 48rpx 0;
}

.hint.err {
  color: #dc2626;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  padding: 40rpx 24rpx 56rpx;
  text-align: center;
}

.empty-illustration {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  border-radius: 32rpx;
  background: linear-gradient(160deg, #eff6ff 0%, #f8fafc 100%);
  border: 2rpx solid #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-antenna {
  position: absolute;
  top: 18rpx;
  width: 36rpx;
  height: 10rpx;
  border-radius: 9999rpx;
  background: #93c5fd;
}

.empty-box {
  width: 72rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #fff;
  border: 2rpx solid #bfdbfe;
  position: relative;
}

.empty-led {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 9999rpx;
  background: #cbd5e1;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #334155;
}

.empty-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.device-row {
  margin-bottom: 28rpx;
  overflow: hidden;
}

.device-inner {
  display: flex;
  align-items: stretch;
}

.device-main {
  flex: 1;
  min-width: 0;
  padding: 44rpx 28rpx;
}

.device-main-hover {
  background: #f8fafc;
}

.device-main-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

/* 左：设备名；右：仅有定时任务时显示时钟图标，与在线徽章并排 */
.device-row-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.device-name-col {
  flex: 1 1 0;
  min-width: 0;
}

.device-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 46rpx;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-id-small {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.3;
  color: #94a3b8;
  font-family: ui-monospace, monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.schedule-side {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
}

/* 扁平化：与「在线」徽章同类 — 浅底 + 主色描边/图形，无渐变与立体阴影 */
.schedule-clock {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  border-radius: 50%;
  box-sizing: border-box;
  background: #eff6ff;
  border: 2rpx solid #2563eb;
}

.schedule-clock-hand {
  position: absolute;
  left: 50%;
  bottom: 50%;
  transform-origin: 50% 100%;
  background: #2563eb;
}

.schedule-clock-hand--hour {
  width: 3rpx;
  height: 10rpx;
  margin-left: -1.5rpx;
  border-radius: 2rpx;
  transform: rotate(-36deg);
}

.schedule-clock-hand--min {
  width: 2rpx;
  height: 13rpx;
  margin-left: -1rpx;
  border-radius: 1rpx;
  transform: rotate(56deg);
}

.schedule-clock-hub {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 4rpx;
  margin-left: -2rpx;
  margin-top: -2rpx;
  border-radius: 50%;
  background: #2563eb;
}

.device-badge-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-on {
  background: #ecfdf5;
  color: #047857;
}

.badge-off {
  background: #f1f5f9;
  color: #64748b;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
}

.dot-on {
  background: #10b981;
}

.dot-off {
  background: #94a3b8;
}

.device-inner .switch-track {
  align-self: center;
  margin-right: 28rpx;
}

.fab-add {
  text-decoration: none;
}

.fab-plus {
  font-size: 64rpx;
  font-weight: 300;
  line-height: 1;
}
