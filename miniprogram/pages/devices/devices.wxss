.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

.hero {
  padding: 40rpx 32rpx 8rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.02em;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.toolbar {
  padding: 16rpx 24rpx 8rpx;
}

.btn-add {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.28);
}

.device .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.meta {
  margin-top: 8rpx;
}

.empty,
.state {
  text-align: center;
  color: #64748b;
  padding: 64rpx 40rpx;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #e0e7ff, #f1f5f9);
  border: 2rpx solid #e2e8f0;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.error-box {
  margin: 24rpx;
  padding: 40rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(15, 23, 42, 0.06);
}

.error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.error-text {
  text-align: left;
  font-size: 24rpx;
  line-height: 1.65;
  color: #b91c1c;
  padding: 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 20rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.btn-retry {
  margin-top: 28rpx;
  width: 100%;
  background: #f8fafc;
  color: #1e293b;
  border-radius: 12rpx;
  font-size: 28rpx;
}
