<view class="page">
  <view class="steps card">
    <view class="step-row">
      <view class="step-item">
        <view class="bubble done">✓</view>
        <text class="step-txt ok">发现</text>
      </view>
      <view class="step-line on"/>
      <view class="step-item">
        <view class="bubble done">✓</view>
        <text class="step-txt ok">配网</text>
      </view>
      <view class="step-line"/>
      <view class="step-item">
        <view class="bubble active">3</view>
        <text class="step-txt on">绑定</text>
      </view>
    </view>
  </view>

  <view class="ok-block">
    <view class="ok-ico">✓</view>
    <text class="ok-title">配网成功</text>
    <text class="ok-sub">设备已联网，将绑定到当前微信账号</text>
  </view>

  <view class="card info">
    <view class="row">
      <text class="k">设备 ID</text>
      <text class="v mono">{{device_id}}</text>
    </view>
    <view class="row">
      <text class="k">固件</text>
      <text class="v">{{fw_version || '—'}}</text>
    </view>
  </view>

  <text class="label">备注名</text>
  <input
    class="input"
    placeholder="例如：客厅灯带"
    value="{{remark}}"
    bindinput="onRemark"
  />

  <button class="btn-primary full" loading="{{submitting}}" bindtap="onBind">完成绑定</button>
</view>
