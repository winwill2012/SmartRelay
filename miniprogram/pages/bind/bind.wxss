.page {
  padding: 24rpx;
}

.label {
  margin: 16rpx 0 8rpx;
  color: #374151;
  font-size: 26rpx;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 8rpx;
}

.btn-primary {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
}

.hint {
  margin-top: 24rpx;
  font-size: 24rpx;
}
