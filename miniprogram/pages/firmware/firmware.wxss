.page {
  padding: 32rpx;
}

.block {
  padding: 32rpx;
  background: linear-gradient(180deg, #fafbff 0%, #fff 55%);
}

.lab {
  font-size: 24rpx;
  color: #64748b;
  display: block;
}

.val {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.mono {
  font-family: ui-monospace, monospace;
}

.btn-check {
  margin-top: 32rpx;
  width: 100%;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 55%, #1d4ed8 100%);
  color: #fff;
  font-weight: 600;
  font-size: 30rpx;
  border-radius: 24rpx;
  line-height: 88rpx;
  padding: 0;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.28);
}

.btn-check::after {
  border: none;
}

.result {
  margin-top: 32rpx;
  padding: 32rpx;
}

.ver {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2563eb;
}

.notes {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
}

.msg {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}
