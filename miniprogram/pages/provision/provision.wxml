<view class="page">
  <view class="steps card">
    <view class="step-row">
      <view class="step-item">
        <view class="bubble {{step>=1 ? 'done' : ''}} {{step===0 ? 'active' : ''}}">{{step>0 ? '✓' : '1'}}</view>
        <text class="step-txt {{step===0 ? 'on' : ''}}">搜索</text>
      </view>
      <view class="step-line"/>
      <view class="step-item">
        <view class="bubble {{step>=2 ? 'done' : ''}} {{step===1 ? 'active' : ''}}">{{step>1 ? '✓' : '2'}}</view>
        <text class="step-txt {{step===1 ? 'on' : ''}}">配网</text>
      </view>
      <view class="step-line"/>
      <view class="step-item">
        <view class="bubble {{step>=3 ? 'active' : ''}}">3</view>
        <text class="step-txt {{step===2 ? 'on' : ''}}">绑定</text>
      </view>
    </view>
  </view>

  <view class="tip-box">
    <text class="tip-txt">设备配网模式：长按 BOOT 约 5 秒至蓝灯快闪。</text>
  </view>

  <view wx:if="{{step===0}}" class="block">
    <button class="btn-primary full" loading="{{scanning}}" bindtap="onScan">搜索设备</button>
    <view wx:if="{{found.length}}" class="found-title">附近设备</view>
    <view
      wx:for="{{found}}"
      wx:key="deviceId"
      class="found-row"
      data-id="{{item.deviceId}}"
      data-name="{{item.name}}"
      bindtap="onPickDevice"
    >
      <text class="found-name">{{item.name || item.localName || '未知'}}</text>
      <text class="found-rssi">{{item.RSSI}} dBm</text>
    </view>
  </view>

  <view wx:if="{{step===1}}" class="block">
    <text class="label">Wi-Fi 网络</text>
    <view class="picker-box">
      <input class="picker-input" placeholder="输入 Wi-Fi 名称" value="{{wifiSsid}}" bindinput="onSsid"/>
      <view class="picker-actions">
        <view class="wifi-refresh" catchtap="refreshWifiList" hover-class="none">
          <text class="wifi-refresh-text {{wifiLoading ? 'loading' : ''}}">刷新</text>
        </view>
        <text class="picker-arrow {{wifiListEnriched.length ? '' : 'muted'}}" bindtap="openWifiSheet">›</text>
      </view>
    </view>

    <text class="label mt">密码</text>
    <view class="pwd-box">
      <input class="pwd-input" password="{{!showPwd}}" placeholder="输入 WiFi 密码" value="{{wifiPwd}}" bindinput="onPwd"/>
      <view class="eye" bindtap="togglePwd">
        <view class="eye-icon {{showPwd ? 'on' : 'off'}}">
          <view class="eye-dot"/>
        </view>
      </view>
    </view>

    <button class="btn-primary full mt-lg" loading="{{provisioning}}" disabled="{{provisioning}}" bindtap="onStartProvision">开始配网</button>
    <button class="btn-ghost full" disabled="{{provisioning}}" bindtap="onCancelWifi">上一步</button>
  </view>

  <view wx:if="{{showWifiSheet}}" class="wifi-mask" bindtap="closeWifiSheet">
    <view class="wifi-sheet" catchtap="stopSheetBubble">
      <view class="wifi-sheet-head">
        <text class="wifi-sheet-title">选择 Wi-Fi</text>
        <text class="wifi-sheet-close" bindtap="closeWifiSheet">关闭</text>
      </view>
      <scroll-view scroll-y class="wifi-sheet-scroll" show-scrollbar="{{false}}">
        <view
          wx:for="{{wifiListEnriched}}"
          wx:key="index"
          class="wifi-sheet-row"
          data-index="{{index}}"
          bindtap="selectWifiRow"
        >
          <text class="wifi-sheet-ssid">{{item.SSID}}</text>
          <view class="wifi-sig wifi-sig--{{item.sigLevel}}">
            <view class="bar"/>
            <view class="bar"/>
            <view class="bar"/>
            <view class="bar"/>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
