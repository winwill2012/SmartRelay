.page {
  padding-bottom: 48rpx;
}

.intro .h3 {
  font-weight: 600;
  margin-bottom: 12rpx;
}

.intro .p {
  color: #4b5563;
  font-size: 26rpx;
}

.label {
  margin: 12rpx 0 8rpx;
  color: #374151;
  font-size: 26rpx;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 8rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  margin-bottom: 16rpx;
}

.btn-secondary {
  background: #f3f4f6;
  color: #111827;
}

.dev {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  display: flex;
  flex-direction: column;
}

.log {
  font-size: 24rpx;
  color: #374151;
  white-space: pre-wrap;
}

.btn-link {
  background: transparent;
  color: #2563eb;
  font-size: 28rpx;
}
