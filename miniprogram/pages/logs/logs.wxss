.page {
  padding: 24rpx 32rpx 80rpx;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 48rpx 0;
}

.hint.err {
  color: #dc2626;
}

.row {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card.row.row--schedule {
  background: linear-gradient(135deg, #fefffe 0%, #f3faf6 100%);
  border: 2rpx solid #e8f4ec;
}

/* 用户下发：极淡色相 + 浅灰边，仅作弱区分 */
.card.row.row--manual-on {
  background: linear-gradient(135deg, #feffff 0%, #f4f9ff 100%);
  border: 2rpx solid #e8eef7;
}

.card.row.row--manual-off {
  background: linear-gradient(135deg, #fffffe 0%, #fffaf5 100%);
  border: 2rpx solid #f5ebe3;
}

.card.row.row--manual {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 2rpx solid #f1f5f9;
}

.card.row.row--default {
  background: #fff;
  border: 2rpx solid #f1f5f9;
}

.row-top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.row-top-main {
  flex: 1;
  min-width: 0;
}

.act {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.operator {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.35;
}

.time {
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.detail {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  word-break: break-all;
}

.more {
  text-align: center;
  padding: 24rpx;
  color: #2563eb;
  font-size: 28rpx;
}
