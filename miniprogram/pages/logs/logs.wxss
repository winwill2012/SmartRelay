.page {
  padding: 24rpx 32rpx 80rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 48rpx 0;
}

.hint.err {
  color: #dc2626;
}

.row {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.row-top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.act {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.time {
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.detail {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  word-break: break-all;
}

.more {
  text-align: center;
  padding: 24rpx;
  color: #2563eb;
  font-size: 28rpx;
}
