<view class="page">
  <view wx:if="{{loading}}" class="hint">加载中…</view>
  <view wx:elif="{{error}}" class="hint err">{{error}}</view>
  <view wx:elif="{{list.length === 0}}" class="hint">暂无日志</view>
  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="card row">
      <view class="row-top">
        <text class="act">{{item.actionLabel}}</text>
        <text class="time">{{item.timeText}}</text>
      </view>
      <text wx:if="{{item.detailText}}" class="detail">{{item.detailText}}</text>
    </view>
    <view wx:if="{{hasMore}}" class="more" bindtap="loadMore">加载更多</view>
  </view>
</view>
