.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f3f6fb;
}

/* 上半：纯色渐变蓝底，白字保证可读 */
.top {
  flex-shrink: 0;
  padding: 72rpx 40rpx 64rpx;
  background: linear-gradient(180deg, #1e3a8a 0%, #1d4ed8 55%, #2563eb 100%);
}

.brand {
  display: flex;
  justify-content: center;
  align-items: center;
}

.brand-logo {
  width: 420rpx;
  max-width: 86%;
  display: block;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

/* 下半：浅灰底，正文深灰、链接深蓝 */
.bottom {
  flex: 1;
  padding: 48rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.wx-btn {
  width: 100%;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 50%, #15803d 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(22, 163, 74, 0.32),
    0 0 0 1rpx rgba(255, 255, 255, 0.2) inset;
}

.wx-btn::after {
  border: none;
}

.wx-btn-label {
  letter-spacing: 0.02em;
}

.legal {
  margin-top: 48rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  row-gap: 8rpx;
  column-gap: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #e2e8f0;
}

.legal-line {
  color: #64748b;
  font-size: 24rpx;
}

.legal-link {
  display: inline;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.legal-link-hover {
  opacity: 0.75;
}
