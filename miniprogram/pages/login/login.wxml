<view class="page">
  <view class="top">
    <view class="brand">
      <image class="brand-logo" src="../../logo.png" mode="widthFix" />
    </view>
  </view>

  <view class="bottom">
    <button class="wx-btn" loading="{{loading}}" bindtap="onWxLogin">
      <text class="wx-btn-label">微信一键登录</text>
    </button>

    <view class="legal">
      <text class="legal-line">登录即表示同意</text>
      <navigator
        class="legal-link"
        url="/pages/user-agreement/user-agreement"
        hover-class="legal-link-hover"
      >《用户协议》</navigator>
      <text class="legal-line">与</text>
      <navigator
        class="legal-link"
        url="/pages/privacy-policy/privacy-policy"
        hover-class="legal-link-hover"
      >《隐私政策》</navigator>
    </view>
  </view>
</view>
