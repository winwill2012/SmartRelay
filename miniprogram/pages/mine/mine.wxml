<view class="page">
  <view class="hero card-gradient">
    <view wx:if="{{!loggedIn}}" class="guest">
      <navigator url="/pages/login/login" class="avatar-btn">登录</navigator>
      <text class="guest-tip">登录后同步设备与账号信息</text>
    </view>
    <view wx:else class="user-top">
      <view class="avatar-static">
        <text class="avatar-static-icon">⏻</text>
      </view>
      <view class="nickname-btn" bindtap="onTapNickname">
        <text class="nickname-text {{nickname ? '' : 'placeholder'}}">{{nickname || '点击设置昵称'}}</text>
      </view>
    </view>

    <view class="stats">
      <view class="stat-box">
        <text class="stat-label">已绑定设备</text>
        <text class="stat-num {{loggedIn ? 'primary' : 'muted'}}">{{deviceCount}}</text>
      </view>
      <view class="stat-box">
        <text class="stat-label">定时任务</text>
        <text class="stat-num">{{scheduleCount}}</text>
      </view>
    </view>
  </view>

  <view class="menu card">
    <navigator url="/pages/notifications/notifications" class="menu-row border">
      <view class="menu-left">
        <text class="menu-ico">🔔</text>
        <text>通知中心</text>
      </view>
      <view class="menu-right">
        <text class="badge-num {{notifyCount > 0 ? 'on' : 'off'}}">{{notifyCount}}</text>
        <text class="chev">›</text>
      </view>
    </navigator>
    <navigator url="/pages/shares/shares" class="menu-row">
      <view class="menu-left">
        <text class="menu-ico">🔗</text>
        <text>分享管理</text>
      </view>
      <text class="chev">›</text>
    </navigator>
  </view>

  <view wx:if="{{loggedIn}}" class="logout-wrap">
    <button class="btn-logout" bindtap="onLogout">退出登录</button>
  </view>
</view>
