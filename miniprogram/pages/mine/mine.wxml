<view class="page">
  <view class="card profile" wx:if="{{user}}">
    <view class="avatar-wrap">
      <image wx:if="{{user.avatar_url}}" class="avatar" src="{{user.avatar_url}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-ph"> </view>
    </view>
    <view class="nick">{{user.nickname || '微信用户'}}</view>
    <view class="text-muted id">ID: {{user.id}}</view>
  </view>

  <view class="card" wx:else>
    <view class="hint">登录后可同步设备与操作记录</view>
    <button class="btn-primary" loading="{{loginLoading}}" bindtap="onWxLogin">微信登录</button>
  </view>

  <view class="card api-card">
    <view class="label">API 地址</view>
    <view class="domain-tip">
      真机与体验版必须使用 <text class="em">HTTPS</text>，并在微信公众平台配置 request 合法域名；手机无法访问 127.0.0.1。
    </view>
    <input class="input" value="{{baseInput}}" placeholder="例如 https://你的域名" bindinput="onBaseInput" />
    <button class="btn-save" bindtap="saveBase">保存并生效</button>
  </view>

  <view class="card" wx:if="{{user}}">
    <button class="btn-logout" bindtap="logout">退出登录</button>
  </view>
</view>
