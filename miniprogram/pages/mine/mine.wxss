.page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card-gradient {
  margin: 32rpx 32rpx 0;
  padding: 40rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #f0f9ff 0%, #e0f2fe 40%, #eef2ff 100%);
  border: 2rpx solid rgba(191, 219, 254, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.08);
}

.guest {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.guest-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #64748b;
}

.user-top {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-picker {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar-picker::after {
  border: none;
}

.avatar-img-inner {
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  display: block;
  border: 4rpx solid #dbeafe;
  box-sizing: border-box;
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  background: #fff;
  border: 4rpx solid #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #64748b;
  padding: 12rpx;
  text-align: center;
  box-sizing: border-box;
  line-height: 1.35;
}

.nickname-input {
  margin-top: 28rpx;
  width: 100%;
  max-width: 420rpx;
  padding: 16rpx 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
}

.profile-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  text-align: center;
  padding: 0 16rpx;
}

.stats {
  margin-top: 48rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-box {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  border: 2rpx solid #f1f5f9;
  text-align: center;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.stat-num {
  display: block;
  margin-top: 12rpx;
  font-size: 48rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: #0f172a;
}

.stat-num.primary {
  color: #2563eb;
}

.stat-num.muted {
  color: #94a3b8;
}

.stat-row {
  margin-top: 12rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.stat-cap {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.menu {
  margin: 32rpx 32rpx 0;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.menu-row.border {
  border-bottom: 2rpx solid #f8fafc;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.menu-ico {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #fffbeb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.menu-row:nth-child(2) .menu-ico {
  background: #f5f3ff;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.badge-num {
  min-width: 36rpx;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  text-align: center;
}

.badge-num.on {
  background: #ef4444;
  color: #fff;
}

.badge-num.off {
  background: #e2e8f0;
  color: #64748b;
}

.chev {
  color: #cbd5e1;
  font-size: 32rpx;
}

.logout-wrap {
  margin: 48rpx 32rpx 0;
}

.btn-logout {
  width: 100%;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: #fff;
  color: #dc2626;
  font-size: 28rpx;
  font-weight: 500;
  padding: 28rpx 0;
}

.btn-logout::after {
  border: none;
}
