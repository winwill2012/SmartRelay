.page {
  padding-bottom: 48rpx;
}

.profile {
  text-align: center;
}

.avatar-wrap {
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #e5e7eb;
}

.avatar-ph {
  display: inline-block;
}

.nick {
  font-size: 34rpx;
  font-weight: 600;
}

.id {
  margin-top: 8rpx;
  word-break: break-all;
}

.hint {
  margin-bottom: 24rpx;
  color: #6b7280;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
}

.label {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: #0f172a;
  font-weight: 600;
}

.domain-tip {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.55;
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border-left: 6rpx solid #2563eb;
}

.domain-tip .em {
  color: #1d4ed8;
  font-weight: 600;
}

.api-card .input {
  background: #fafafa;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.btn-save {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
}

.btn-logout {
  background: #fff;
  color: #b91c1c;
  border: 1rpx solid #fecaca;
}
