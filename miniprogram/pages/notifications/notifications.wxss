.page {
  padding: 24rpx 32rpx 80rpx;
}

.hint {
  text-align: center;
  color: #64748b;
  padding: 48rpx 0;
}

.card.item {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.dot {
  font-size: 22rpx;
  color: #ef4444;
  flex-shrink: 0;
}

.body {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.45;
}

.time {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}
