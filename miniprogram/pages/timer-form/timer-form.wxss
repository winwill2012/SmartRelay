.page {
  padding: 24rpx 32rpx 80rpx;
}

.form {
  padding: 32rpx;
}

.field {
  margin-bottom: 40rpx;
}

.lab {
  font-size: 24rpx;
  font-weight: 500;
  color: #475569;
}

.inp {
  margin-top: 12rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: #fafafa;
  font-size: 28rpx;
}

.repeat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #e2e8f0;
  background: #fff;
  color: #334155;
}

.chip.on {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.25);
}

.sub-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #f1f5f9;
  background: #f8fafc;
}

.sub-lab {
  font-size: 24rpx;
  font-weight: 500;
  color: #475569;
}

.week-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.wchip {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: #fff;
  color: #334155;
}

.wchip.on {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.mchip {
  min-height: 72rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  background: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #334155;
}

.mchip.on {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

.sub-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.row2 {
  display: flex;
  gap: 32rpx;
}

.field.half {
  flex: 1;
  min-width: 0;
}

.picker-val {
  margin-top: 12rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  font-size: 28rpx;
  color: #0f172a;
}

.btn-save {
  margin-top: 16rpx;
  width: 100%;
  background: #2563eb;
  color: #fff;
  font-weight: 600;
  border-radius: 24rpx;
  padding: 28rpx 0;
}

.btn-save::after {
  border: none;
}
